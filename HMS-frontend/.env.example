# ══════════════════════════════════════════════════════════
#  HMS Frontend — Environment Variables
#  Copy this file to .env.local and fill in the values.
#  .env.local is gitignored — never commit it.
# ══════════════════════════════════════════════════════════

# Backend URL — use /api for local dev (Vite proxy to localhost:9001)
VITE_API_URL=/api

# ── Dev mock auth (bypasses SSO for local development) ────────────────────
# Get the actual values from the project lead — do NOT leave these empty.
VITE_DEV_MOCK_AUTH=true
VITE_MOCK_USER_ID=
VITE_MOCK_USER_EMAIL=
VITE_MOCK_USER_ROLE=hospital_admin
VITE_MOCK_HOSPITAL_ID=
VITE_MOCK_JWT=
