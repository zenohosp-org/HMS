{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api-hms.zenohosp.com/api/$1"
    },
    {
      "source": "/oauth2/(.*)",
      "destination": "https://api-hms.zenohosp.com/oauth2/$1"
    },
    {
      "source": "/login/(.*)",
      "destination": "https://api-hms.zenohosp.com/login/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}